<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    tools:context=".activities.ProfileActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/brand_dark_green">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/my_profile"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_sprout"
            app:navigationIconTint="@color/brand_gold" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="500dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center_horizontal">

                    <!-- Avatar -->
                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:src="@drawable/ic_user_avatar"
                        android:background="@drawable/rounded_square_bg"
                        android:padding="16dp"
                        app:tint="@color/brand_green"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/profile_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginBottom="24dp"
                        tools:text="rajputmohitsingh715@gmail.com"/>

                    <!-- Form Fields -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/full_name"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="8dp"/>
                    <EditText
                        android:id="@+id/input_full_name_profile"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_edit_text"
                        android:inputType="textPersonName"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:layout_marginBottom="16dp"
                        tools:text="Mohit Singh"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/mobile"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="8dp"/>
                    <EditText
                        android:id="@+id/input_mobile_profile"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_edit_text"
                        android:inputType="phone"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:layout_marginBottom="16dp"
                        tools:text="8652872732"/>
                        
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/gender"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="8dp"/>
                    <Spinner
                        android:id="@+id/spinner_gender_profile"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/bg_spinner"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:layout_marginBottom="32dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/save_changes_button"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="@string/save_changes"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/brand_green"
                        app:cornerRadius="12dp"
                        android:layout_marginBottom="12dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/logout_button"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Logout"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/white"
                        android:textColor="@android:color/holo_red_dark"
                        app:strokeColor="@android:color/holo_red_dark"
                        app:strokeWidth="1dp"
                        app:cornerRadius="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/layout_custom_nav" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
