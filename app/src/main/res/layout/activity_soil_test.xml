<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    tools:context=".activities.SoilTestActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/brand_dark_green">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/new_soil_test"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_sprout"
            app:navigationIconTint="@color/brand_gold" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Initial Upload State -->
            <LinearLayout
                android:id="@+id/upload_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/select_farm"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp"/>

                <Spinner
                    android:id="@+id/farm_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/soil_test_tube_image"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/upload_box"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_upload_box"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/upload_image_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"/>

                    <ImageView
                        android:id="@+id/upload_icon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_gallery"
                        app:tint="@color/text_hint" />
                    <TextView
                        android:id="@+id/upload_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/select_from_gallery"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/predict_button"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="@string/predict_soil_health"
                    app:backgroundTint="@color/brand_green"
                    app:cornerRadius="12dp" />

            </LinearLayout>

            <!-- Empty Prediction Message -->
            <LinearLayout
                android:id="@+id/empty_prediction_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:layout_marginTop="32dp">
                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_bar_chart"
                    app:tint="@color/text_hint"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/empty_prediction_message"
                    android:textColor="@color/text_hint"
                    android:gravity="center"
                    android:layout_marginTop="16dp"/>
            </LinearLayout>


            <!-- Results State -->
            <LinearLayout
                android:id="@+id/results_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="16dp">

                <include layout="@layout/layout_soil_test_results" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
