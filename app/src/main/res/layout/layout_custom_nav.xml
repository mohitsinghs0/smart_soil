<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="110dp"
    android:background="@android:color/transparent">

    <View
        android:id="@+id/nav_background"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_marginHorizontal="16dp"
        android:elevation="9dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="@id/nav_background"
        app:layout_constraintEnd_toEndOf="@id/nav_background"
        app:layout_constraintStart_toStartOf="@id/nav_background">

        <!-- History / List -->
        <LinearLayout
            android:id="@+id/btn_nav_history"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/iv_nav_history"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_list"
                app:tint="#8E8E93" />
            <View
                android:id="@+id/dot_nav_history"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/dot_indicator"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- Tasks / Disabled Leaf -->
        <LinearLayout
            android:id="@+id/btn_nav_tasks"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/iv_nav_tasks"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_sprout_disabled"
                app:tint="#8E8E93" />
            <View
                android:id="@+id/dot_nav_tasks"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/dot_indicator"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- Spacer for Center Button -->
        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2" />

        <!-- Bookmark -->
        <LinearLayout
            android:id="@+id/btn_nav_bookmark"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/iv_nav_bookmark"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_bookmark"
                app:tint="#8E8E93" />
            <View
                android:id="@+id/dot_nav_bookmark"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/dot_indicator"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- Settings / Profile -->
        <LinearLayout
            android:id="@+id/btn_nav_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/iv_nav_settings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                app:tint="#8E8E93" />
            <View
                android:id="@+id/dot_nav_settings"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/dot_indicator"
                android:visibility="invisible" />
        </LinearLayout>

    </LinearLayout>

    <!-- Center Floating Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_nav_center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="36dp"
        android:src="@drawable/ic_sprout"
        app:backgroundTint="@color/brand_green"
        app:tint="@color/white"
        app:fabSize="normal"
        app:elevation="12dp"
        app:borderWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
