<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="110dp"
    android:layout_gravity="bottom"
    android:background="@android:color/transparent">

    <View
        android:id="@+id/nav_background"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_marginHorizontal="12dp"
        android:elevation="11dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="@id/nav_background"
        app:layout_constraintEnd_toEndOf="@id/nav_background"
        app:layout_constraintStart_toStartOf="@id/nav_background">

        <!-- 1st: Soil History -->
        <LinearLayout
            android:id="@+id/btn_nav_history"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/iv_nav_history"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_list"
                android:contentDescription="History"
                app:tint="#8E8E93" />
            <View
                android:id="@+id/dot_nav_history"
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/dot_indicator"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- 2nd: About -->
        <LinearLayout
            android:id="@+id/btn_nav_about"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/iv_nav_about"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_graduation_cap"
                android:contentDescription="About"
                app:tint="#8E8E93" />
            <View
                android:id="@+id/dot_nav_about"
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/dot_indicator"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- Spacer for 3rd: Home (Center) -->
        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2" />

        <!-- 4th: Profile -->
        <LinearLayout
            android:id="@+id/btn_nav_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/iv_nav_profile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_person"
                android:contentDescription="Profile"
                app:tint="#8E8E93" />
            <View
                android:id="@+id/dot_nav_profile"
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/dot_indicator"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- 5th: Settings -->
        <LinearLayout
            android:id="@+id/btn_nav_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/iv_nav_settings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                android:contentDescription="Settings"
                app:tint="#8E8E93" />
            <View
                android:id="@+id/dot_nav_settings"
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/dot_indicator"
                android:visibility="invisible" />
        </LinearLayout>

    </LinearLayout>

    <!-- 3rd: Home Page (Floating Center Button) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_nav_center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="38dp"
        android:src="@drawable/ic_home"
        android:contentDescription="Home"
        app:backgroundTint="@color/brand_green"
        app:tint="@color/white"
        app:fabSize="normal"
        app:elevation="14dp"
        app:borderWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
