<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Farm Name -->
        <TextView
            android:id="@+id/farm_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/more_button"
            tools:text="Rice" />

        <!-- More Options Button -->
        <ImageView
            android:id="@+id/more_button"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_more_vertical"
            app:tint="@color/text_secondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/farm_name"
            app:layout_constraintBottom_toBottomOf="@id/farm_name"
            android:contentDescription="More Options"/>

        <!-- Location -->
        <ImageView
            android:id="@+id/location_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_map_pin"
            android:layout_marginTop="4dp"
            app:tint="@color/text_secondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/farm_name" />

        <TextView
            android:id="@+id/farm_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@id/location_icon"
            app:layout_constraintTop_toTopOf="@id/location_icon"
            app:layout_constraintBottom_toBottomOf="@id/location_icon"
            tools:text="Kondhana, Maharashtra" />

        <!-- Weather Info Box -->
        <LinearLayout
            android:id="@+id/weather_info_box"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_weather_info"
            android:padding="12dp"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/location_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Temperature -->
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_temperature"
                app:tint="@color/text_secondary"
                android:layout_marginEnd="4dp"/>
            <TextView
                android:id="@+id/weather_temp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="27.1°C"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginEnd="16dp"/>

            <!-- Humidity -->
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_humidity"
                app:tint="@color/text_secondary"
                android:layout_marginEnd="4dp"/>
            <TextView
                android:id="@+id/weather_humidity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="45%"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginEnd="16dp"/>

            <!-- Wind -->
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_wind"
                app:tint="@color/text_secondary"
                android:layout_marginEnd="4dp"/>
            <TextView
                android:id="@+id/weather_wind"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="9.4 km/h"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Last Test Info -->
        <TextView
            android:id="@+id/last_test_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Last test: 09/03/2026 • Rice"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/weather_info_box"
            app:layout_constraintStart_toStartOf="parent"/>


        <!-- Action Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/test_button"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="@string/test"
            android:backgroundTint="@color/brand_green"
            app:cornerRadius="12dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toBottomOf="@id/last_test_info"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/history_button" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/history_button"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:text="@string/history"
            android:textColor="@color/brand_green"
            app:strokeColor="@color/brand_green"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toBottomOf="@id/last_test_info"
            app:layout_constraintStart_toEndOf="@id/test_button"
            app:layout_constraintEnd_toEndOf="parent" />


    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
