<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Card Style -->
    <style name="CardStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">16dp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:background">@drawable/card_background</item>
    </style>
    
    <!-- Button Styles -->
    <style name="ButtonStyle.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">8dp</item>
    </style>
    
    <style name="ButtonStyle.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="strokeColor">@color/primary</item>
        <item name="cornerRadius">8dp</item>
    </style>
    
    <!-- EditText Style -->
    <style name="EditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:padding">12dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
    </style>
    
    <!-- Text Styles -->
    <style name="TextStyle" parent="android:Widget.TextView">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextStyle.Heading1" parent="TextStyle">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextStyle.Heading2" parent="TextStyle">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextStyle.Heading3" parent="TextStyle">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextStyle.Body" parent="TextStyle">
        <item name="android:textSize">14sp</item>
    </style>
    
    <style name="TextStyle.Caption" parent="TextStyle">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <!-- Badge Styles -->
    <style name="BadgeStyle" parent="android:Widget.TextView">
        <item name="android:textSize">10sp</item>
        <item name="android:paddingLeft">8dp</item>
        <item name="android:paddingRight">8dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="BadgeStyle.Low" parent="BadgeStyle">
        <item name="android:background">@color/status_low</item>
        <item name="android:textColor">@color/white</item>
    </style>
    
    <style name="BadgeStyle.Medium" parent="BadgeStyle">
        <item name="android:background">@color/status_medium</item>
        <item name="android:textColor">@color/white</item>
    </style>
    
    <style name="BadgeStyle.High" parent="BadgeStyle">
        <item name="android:background">@color/status_high</item>
        <item name="android:textColor">@color/white</item>
    </style>
</resources>
